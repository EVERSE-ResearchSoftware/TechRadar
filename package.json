{
  "name": "techradar",
  "version": "1.0.0",
  "description": "Discovery-first platform for research software quality tools",
  "type": "module",
  "private": true,
  "scripts": {
    "serve": "vite --port 3000",
    "build": "vite build",
    "generate:snapshot": "node scripts/snapshot.js",
    "fmt": "prettier --write \"data/**/*.json\"",
    "fmt:check": "prettier --check \"data/**/*.json\""
  },
  "dependencies": {
    "js-yaml": "^4.1.0",
    "fuse.js": "^7.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@babel/preset-env": "^7.24.0",
    "ajv": "^8.12.0",
    "ajv-formats": "^2.1.1",
    "babel-jest": "^29.7.0",
    "jest": "^29.7.0",
    "prettier": "^3.3.0",
    "vite": "^5.2.0"
  },
  "jest": {
    "testEnvironment": "node",
    "transform": { "^.+\\.js$": "babel-jest" },
    "testMatch": ["**/tests/**/*.test.js"],
    "collectCoverageFrom": ["src/utils/**/*.js", "scripts/**/*.js"]
  }
}
